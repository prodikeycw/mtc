# ── Media files (inputs/outputs — never commit) ─────────────────────────────
*.mp4
*.mkv
*.webm
*.avi
*.mov
*.m4a
*.mp3
*.wav
*.flac
*.ogg

# ── Transcript outputs ───────────────────────────────────────────────────────
*.txt
*.vtt
*.srt
*.ass
*.json

# ── Whisper models (large binary files) ─────────────────────────────────────
*.bin
*.pt
*.gguf
models/

# ── Credentials and secrets ──────────────────────────────────────────────────
.env
.env.*
*.key
*.pem
*.p12
*.pfx
cookies.txt
.netrc
secrets/

# ── macOS system files ───────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
._*

# ── Logs and temp ────────────────────────────────────────────────────────────
*.log
*.tmp
tmp/
temp/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/
